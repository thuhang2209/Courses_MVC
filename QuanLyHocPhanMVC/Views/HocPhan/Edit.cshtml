@model QuanLyHocPhanMVC.Models.HocPhan

@{
    ViewData["Title"] = "Cập nhật học phần";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="custom-card shadow-sm border-0">
            <div class="text-center mb-4">
                <div class="bg-success text-white d-inline-flex align-items-center justify-content-center rounded-circle mb-3 shadow" style="width: 60px; height: 60px;">
                    <i class="bi bi-pencil-square fs-3"></i>
                </div>
                <h2 class="fw-bold">Chỉnh sửa học phần</h2>
                <p class="text-muted small">Cập nhật thông tin mới nhất cho mã học phần: <span class="fw-bold text-dark">@Model.MaHocPhan</span></p>
            </div>

            <form method="post">
                <input type="hidden" name="IDHocPhan" value="@Model.IDHocPhan" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Mã học phần</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash text-muted"></i></span>
                        <input type="text" name="MaHocPhan" class="form-control border-start-0 bg-white" value="@Model.MaHocPhan" readonly />
                    </div>
                    <small class="text-muted px-1">Mã định danh không thể thay đổi</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tên học phần</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-bookmark-fill text-muted"></i></span>
                        <input type="text" name="TenHocPhan" class="form-control border-start-0" value="@Model.TenHocPhan" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Số tín chỉ</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-123 text-muted"></i></span>
                        <input type="number" name="SoTinChi" class="form-control border-start-0" value="@Model.SoTinChi" min="1" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Mô tả học phần</label>
                    <textarea name="MoTa" class="form-control" rows="3" style="border-radius: 12px;">@Model.MoTa</textarea>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary py-3 fw-bold shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i> Lưu thay đổi
                    </button>
                    <a href="/HocPhan/DanhSach" class="btn btn-light py-2 text-muted fw-semibold">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>